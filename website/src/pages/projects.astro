---
import Project from "../components/Project.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<main class="bg-primary">
        <section>
            <h1>tools</h1>
            <div class="grid grid-cols-2 gap-1 m-1">
                <Project href="https://git.lunartides.dev/LunarTides">
                    lunsrc
                    <p class="hint">my forgejo instance running on <code>sunlight</code></p>
                </Project>
                <Project href="https://vault.lunartides.dev">
                    vaultwarden
                    <p class="hint">my vaultwarden instance. should be secure enough.<br>runs on <code>sunlight</code> incase i'm in a foreign enviornment where i don't have access to my usual devices</p>
                </Project>
            </div>
        </section>

        <!-- <hr class="text-ctp-crust" /> -->

        <p>projects</p>
        <div class="grid grid-cols-2 gap-1 m-1">
      		<Project href="https://hs.lunartides.dev" title="hearthstone.js">
    			hearthstone.js
    			<p class="hint">a console-based recreation of hearthstone in progress since 2022<br>my proudest achievement with &gt;1800 commits and &gt;45k lines of code<br><br>huge monorepo with a lot of history made with bun. includes a wiki and a npm-inspired registry for community-generated content<br>allows easily creating custom cards, sfx, commands</p>
    		</Project>
    		<Project href="https://lunartides.dev" title="lunartides.dev">
    			lunartides.dev
    			<p class="hint">this website. includes all subdomains. runs on an old laptop turned ubuntu server in a laundry room<br>internally called <code>sunlight</code>, since it's the front-facing side of my website, publically accessible to everyone</p>
    		</Project>
    		<Project href="https://git.lunartides.dev/LunarTides/chalk-tags" title="chalk tags">
    			chalk tags
    			<p class="hint">an npm library to add html-inspired tags to color text<br>e.g. &lt;red bg:blue&gt;some red text on blue background&lt;/red bg:blue&gt;</p>
    		</Project>
    		<Project href="https://git.lunartides.dev/LunarTides/HearthstoneVanillaTypes" title="hearthstone vanilla types">
    			hearthstone vanilla types
    			<p class="hint">an npm library with auto-generated types for vanilla hearthstone cards.<br>used together with the hearthstonejson.com api</p>
    		</Project>
    		<Project href="https://git.lunartides.dev/LunarTides/astroneer-lookup-rust" title="astroneer lookup">
    			astroneer lookup
    			<p class="hint">a tool to see the complete resource tree for every item / building in astroneer</p>
    		</Project>
    		<Project href="https://git.lunartides.dev/LunarTides/vesma" title="vesma">
    			vesma (wip)
    			<p class="hint">like astroneer lookup but more generic<br>works for every survival game, as long as an associated "pack" exists for that game</p>
    		</Project>
    		<Project href="https://git.lunartides.dev/LunarTides/zuno" title="zuno">
    			zuno (abandoned)
    			<p class="hint">uno in zig</p>
    		</Project>
    		<Project href="https://git.lunartides.dev/LunarTides/Hearthstone.gd" title="hearthstone.gd">
    			hearthstone.gd (abandoned)
    			<p class="hint">hearthstone.js but in godot<br>abandoned due to poor early design decisions. might revive in a rewrite from the ground up</p>
    		</Project>
    		<Project href="https://git.lunartides.dev/LunarTides/Login-Thing" title="login thing">
    			login thing (abandoned)
    			<p class="hint">extremely old website made in php. i just followed a php login tutorial and just added things i thought of<br>this was back when i thought you <em>needed</em> to use php to add accounts and session states<br>i've come a long way. this is just here for historical reasons i guess</p>
    		</Project>
        </div>
    </main>
</Layout>
