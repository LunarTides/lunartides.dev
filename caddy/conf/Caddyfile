{
	# Get staging certificate. Remove in production.
	#acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

	servers {
		trusted_proxies static private_ranges
    }
}

# --- Public Facing ---

lunartides.dev {
    reverse_proxy http://anubis:3000 {
        header_up Host {host}
        header_up X-Real-Ip {remote_host}
        header_up X-Http-Version {http.request.proto}
        header_up X-Forwarded-Proto https
        header_up Forwarded "for={remote_host};proto=https"
    }
}

hs.lunartides.dev {
    reverse_proxy http://anubis:3000 {
        header_up Host {host}
        header_up X-Real-Ip {remote_host}
        header_up X-Http-Version {http.request.proto}
        header_up X-Forwarded-Proto https
        header_up Forwarded "for={remote_host};proto=https"
    }
}

git.lunartides.dev {
    # Use port 3000 when setting up for the first time.
    #reverse_proxy forgejo:3000 {
    reverse_proxy forgejo:80 {
        header_up X-Real-IP {remote_host}
    }
}

vault.lunartides.dev {
    respond /admin* "Access Denied" 403 {
        close
    }

    # Don't use anubis when accessing vault. This makes the Bitwarden addon fail.
    reverse_proxy vaultwarden:80 {
        header_up X-Real-Ip {remote_host}
    }
}

# --- Internal (After Anubis) ---
http://hs.lunartides.dev:8080 {
    # Handle registry path.
    @registry path_regexp registry ^/registry(/.*)?$
    handle @registry {
        reverse_proxy http://registry-frontend:80
    }

    handle {
        encode
        root * /var/www/docs
        try_files {path} {path}/index.html =404
        file_server
    }
}

http://lunartides.dev:8080 {
    encode
   	root * /var/www/website
   	file_server
}
